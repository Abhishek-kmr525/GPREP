        <ul class="breadcrumb-menu">
          <li><a href="{{ front_page }}">Home</a></li>
          <li><a href="/news">News</a></li>
          <li class="active">{{ news_detail_item.title }}</li>
        </ul>
      </div>
    </div>

    <div class="blog-single-area pt-5 pb-5 contentsAreaPanel">
      <div class="container">
        <div class="row">
          <div class="col-lg-8">
            <div class="blog-single-wrapper">
              <div class="blog-single-content">
                {% if news_detail_item.image_url %}
                  <div class="blog-thumb-img">
                    <img src="{{ news_detail_item.image_url }}" alt="{{ news_detail_item.image_alt ?: news_detail_item.title }}">
                  </div>
                {% endif %}
                <div class="blog-info">
                  <div class="blog-meta">
                    <div class="blog-meta-left">
                      <ul class="mb-0">
                        <li><i class="far fa-calendar-alt"></i><a href="#">{{ news_detail_item.display_date_long }}</a></li>
                        {% if news_detail_item.display_time %}
                          <li><i class="far fa-clock"></i> {{ news_detail_item.display_time }}</li>
                        {% endif %}
                        {% if news_detail_item.incident %}
                          <li><i class="fa-regular fa-brake-warning"></i> {{ news_detail_item.incident }}</li>
                        {% endif %}
                      </ul>
                    </div>
                    {% if news_detail_item.source_url %}
                      <div class="blog-meta-right">
                        <a href="{{ news_detail_item.source_url }}" class="share-btn" target="_blank" rel="noopener noreferrer"><i class="far fa-share-alt"></i>Source</a>
                      </div>
                    {% endif %}
                  </div>
                  <div class="blog-details">
                    <h3 class="blog-details-title mb-20">{{ news_detail_item.title }}</h3>
                    {{ news_detail_item.body|raw }}
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="col-lg-4">
            <aside class="sidebar">
              <div class="widget search">
                <h5 class="widget-title">Search</h5>
                <form class="search-form" action="/news" method="get">
                  <input type="text" class="form-control" name="q" placeholder="Search Here...">
                  <button type="submit"><i class="far fa-search"></i></button>
                </form>
              </div>

              <div class="widget category">
                <h5 class="widget-title">Incident</h5>
                <div class="category-list">
                  {% for incident in news_page_incidents %}
                    <a href="{{ incident.url }}"{% if news_detail_item.incident == incident.name %} class="active"{% endif %}><i class="far fa-arrow-right"></i>{{ incident.name }} <span>({{ incident.count }})</span></a>
                  {% endfor %}
                </div>
              </div>

              <div class="widget recent-post">
                <h5 class="widget-title">Recent Post</h5>
                {% for item in news_page_recent_items %}
                  <div class="recent-post-single">
                    <div class="recent-post-img">
                      {% if item.image_url %}
                        <img src="{{ item.image_url }}" alt="{{ item.image_alt ?: item.title }}">
                      {% endif %}
                    </div>
                    <div class="recent-post-bio">
                      <div class="d-flex justify-content-between align-items-center mb-2">
                        <span><i class="far fa-clock"></i>{{ item.display_date }}</span>
                        {% if item.incident %}
                          <span style="color:#000"><i class="fa-regular fa-brake-warning"></i>{{ item.incident }}</span>
                        {% endif %}
                      </div>
                      <h6><a href="{{ item.url }}">{{ item.title }}</a></h6>
                    </div>
                  </div>
                {% endfor %}
              </div>
            </aside>
          </div>
        </div>
      </div>
    </div>
  {% elseif is_contact_page %}
    <div class="site-breadcrumb" style="background: url('{{ theme_path }}/assets/img/breadcrumb/01.jpg')">
      <div class="container">
        <h2 class="breadcrumb-title">Contact Us</h2>
        <ul class="breadcrumb-menu">
          <li><a href="{{ front_page }}">Home</a></li>
          <li class="active">Contact Us</li>
        </ul>
      </div>
    </div>

    <div class="contact-area py-120">
      <div class="container">
        <div class="contact-content">
          <div class="row">
            <div class="col-md-3">
              <div class="contact-info">
                <div class="contact-info-icon">
                  <i class="fal fa-map-location-dot"></i>
                </div>
                <div class="contact-info-content">
                  <h5>Office Address</h5>
                  <p>{{ gprep_settings.address|nl2br }}</p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="contact-info">
                <div class="contact-info-icon">
                  <i class="fal fa-phone-volume"></i>
                </div>
                <div class="contact-info-content">
                  <h5>Call Us</h5>
                  <p>{{ gprep_settings.phone }}</p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="contact-info">
                <div class="contact-info-icon">
                  <i class="fal fa-envelopes"></i>
                </div>
                <div class="contact-info-content">
                  <h5>Email Us</h5>
                  <p><a href="mailto:{{ gprep_settings.email }}">{{ gprep_settings.email }}</a></p>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="contact-info">
                <div class="contact-info-icon">
                  <i class="fal fa-alarm-clock"></i>
                </div>
                <div class="contact-info-content">
                  <h5>{{ gprep_settings.emergency_label }}</h5>
                  <p>{{ gprep_settings.emergency_phone }}</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="contact-wrapper">
          <div class="row">
            <div class="col-lg-5">
              <div class="contact-img">
                <img src="{{ theme_path }}/assets/img/contact/01.jpg" alt="Contact">
              </div>
            </div>
            <div class="col-lg-7 align-self-center">
              <div class="contact-form">
                <div class="contact-form-header">
                  <h2>Get In Touch</h2>
                  <p>It is a long established fact that a reader will be distracted by the readable content of a page randomised words which don't look even slightly when looking at its layout.</p>
                </div>
                {{ contact_page_form }}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    {% if gprep_settings.map_embed_url %}
      <div class="contact-map">
        <iframe src="{{ gprep_settings.map_embed_url }}" title="Office location map" width="100%" height="450" style="border:0;" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    {% endif %}
  {% elseif is_map_page %}
    <div class="event-area contentsAreaPanel">
      {% if gprep_settings.map_embed_url %}
        <iframe src="{{ gprep_settings.map_embed_url }}" title="Interactive regional emergency map" width="100%" height="700" style="border:1px solid #ccc;" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      {% endif %}
    </div>
  {% endif %}

  {% if page_content|striptags|trim and not is_resource_item_page and not is_news_item_page %}
    <div class="layout-content">
      {{ page_content|raw }}
    </div>
  {% endif %}
</main>

{% if show_emergency_homepage %}
  <footer class="footer-area footerEmergencyArea">
    <div class="footer-widget">
      <div class="container">
        <div class="footer-widget-wrapper pt-40 pb-20">
          <div class="footer-widget-box about-us text-center mb-0">
            <a href="{{ front_page }}" class="footer-logo">
              <img src="{{ theme_path }}/assets/img/logo/logo-light.png" alt="GPREP logo">
            </a>
            <ul class="footer-contact d-block d-md-flex justify-content-center gap-5 mt-3">
              <li class="d-flex text-start foter-Icon-Box gap-3">
                <i class="fal fa-phone-volume me-0"></i>
                <span>{{ gprep_settings.emergency_label }}<br><strong>{{ gprep_settings.emergency_phone }}</strong></span>
              </li>
              <li class="d-flex text-start foter-Icon-Box gap-3">
                <i class="far fa-phone me-0"></i>
                <span>Call Centre<br><strong>{{ gprep_settings.phone }}</strong></span>
              </li>
              <li class="d-flex text-start foter-Icon-Box gap-3">
                <i class="far fa-envelope me-0"></i>
                <span>Email Id<br><strong>{{ gprep_settings.email }}</strong></span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
    <div class="copyright">
      <div class="container">
        <div class="d-flex justify-content-between">
          <div class="col-md-6 align-self-center">
            <p class="copyright-text">&copy; {{ gprep_settings.footer_copyright }}</p>
          </div>
          <ul class="footer-social">
            {% if gprep_settings.facebook_url %}
              <li><a href="{{ gprep_settings.facebook_url }}"><i class="fab fa-facebook-f"></i></a></li>
            {% endif %}
            {% if gprep_settings.twitter_url %}
              <li><a href="{{ gprep_settings.twitter_url }}"><i class="fab fa-x-twitter"></i></a></li>
            {% endif %}
          </ul>
        </div>
      </div>
    </div>
  </footer>
{% else %}
  <footer class="footer-area">
    <div class="footer-widget">
      <div class="container">
        <div class="row footer-widget-wrapper pt-70 pb-20">
          <div class="col-md-6 col-lg-3">
            <div class="footer-widget-box about-us">
              <a href="{{ front_page }}" class="footer-logo mb-3">
                <img src="{{ theme_path }}/assets/img/logo/logo-light.png" alt="GPREP logo">
              </a>
              <ul class="footer-contact">
                {% if gprep_settings.phone %}
                  <li><a href="tel:{{ gprep_settings.phone_link }}"><i class="far fa-phone"></i> {{ gprep_settings.phone }}</a></li>
                {% endif %}
                {% if gprep_settings.emergency_phone %}
                  <li><i class="far fa-phone"></i> {{ gprep_settings.emergency_label }} ({{ gprep_settings.emergency_phone }})</li>
                {% endif %}
                {% if gprep_settings.email %}
                  <li><a href="mailto:{{ gprep_settings.email }}"><i class="far fa-envelope"></i> {{ gprep_settings.email }}</a></li>
                {% endif %}
              </ul>
            </div>
          </div>
          <div class="col-md-6 col-lg-7">
            <div class="footer-widget-box list">
              <h4 class="footer-widget-title">Resources</h4>
              <ul class="footer-list resourcesFooterArea">
                {% for item in footer_resources_menu_items %}
                  <li><a href="{{ item.url }}"><i class="fas fa-caret-right"></i>{{ item.title|striptags }}</a></li>
                {% endfor %}
              </ul>
            </div>
          </div>
          <div class="col-md-6 col-lg-2">
            <div class="footer-widget-box list">
              <h4 class="footer-widget-title">Quick Link</h4>
              <ul class="footer-list">
                {% for item in footer_quick_links_menu_items %}
                  <li><a href="{{ item.url }}"><i class="fas fa-caret-right"></i> {{ item.title|striptags }}</a></li>
                {% endfor %}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="copyright">
      <div class="container">
        <div class="d-flex justify-content-between">
          <div class="col-md-6 align-self-center">
            <p class="copyright-text">
              &copy; {{ gprep_settings.footer_copyright }}
            </p>
          </div>
          <ul class="footer-social">
            {% if gprep_settings.facebook_url %}
              <li><a href="{{ gprep_settings.facebook_url }}"><i class="fab fa-facebook-f"></i></a></li>
            {% endif %}
            {% if gprep_settings.twitter_url %}
              <li><a href="{{ gprep_settings.twitter_url }}"><i class="fab fa-x-twitter"></i></a></li>
            {% endif %}
          </ul>
        </div>
      </div>
    </div>
  </footer>
{% endif %}
