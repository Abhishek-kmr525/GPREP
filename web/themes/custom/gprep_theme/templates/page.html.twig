<header class="header{% if show_emergency_homepage %} emergency-header-only{% endif %}">
  <div class="header-top">
    <div class="container">
      <div class="header-top-wrapper">
        <div class="header-top-left">
          <div class="header-top-contact">
            <ul>
              {% if gprep_settings.phone %}
                <li><a href="tel:{{ gprep_settings.phone_link }}"><i class="far fa-phone"></i> {{ gprep_settings.phone }}</a></li>
              {% endif %}
              {% if gprep_settings.email %}
                <li><a href="mailto:{{ gprep_settings.email }}"><i class="far fa-envelopes"></i> {{ gprep_settings.email }}</a></li>
              {% endif %}
              {% if gprep_settings.emergency_phone %}
                <li{% if not show_emergency_homepage %} class="d-lg-none"{% endif %}><a href="tel:{{ gprep_settings.emergency_phone_link }}"><i class="far fa-phone"></i> {{ gprep_settings.emergency_label }} ({{ gprep_settings.emergency_phone }})</a></li>
              {% endif %}
            </ul>
          </div>
        </div>
        <div class="header-top-right">
          <div class="header-top-social">
            <span>Follow Us: </span>
            {% if gprep_settings.facebook_url %}
              <a href="{{ gprep_settings.facebook_url }}"><i class="fab fa-facebook-f"></i></a>
            {% endif %}
            {% if gprep_settings.twitter_url %}
              <a href="{{ gprep_settings.twitter_url }}"><i class="fab fa-x-twitter"></i></a>
            {% endif %}
          </div>
          <div class="dropdown languageArea">
            <button class="btn dropdown-toggle" type="button" id="dropdownMenuButton1" data-bs-toggle="dropdown" aria-expanded="false">
              {{ gprep_settings.language_label }}
            </button>
            <ul class="dropdown-menu" aria-labelledby="dropdownMenuButton1">
              <li><a class="dropdown-item" href="#">English</a></li>
              <li><a class="dropdown-item" href="#">French</a></li>
              <li><a class="dropdown-item" href="#">Spanish</a></li>
              <li><a class="dropdown-item" href="#">Italian</a></li>
              <li><a class="dropdown-item" href="#">German</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  {% if not show_emergency_homepage %}
    <div class="main-navigation">
      <nav class="navbar navbar-expand-lg" aria-label="Primary navigation">
        <div class="container position-relative">
          <a class="navbar-brand" href="{{ front_page }}">
            <img src="{{ theme_path }}/assets/img/logo/logo-light.png" class="logo-display" alt="GPREP logo">
            <img src="{{ theme_path }}/assets/img/logo/logo.png" class="logo-scrolled" alt="GPREP logo">
          </a>

          <div class="mobile-menu-right">
            <div class="search-btn">
              <button type="button" class="nav-right-link"><i class="far fa-search"></i></button>
            </div>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#main_nav" aria-expanded="false" aria-label="Toggle navigation">
              <span class="navbar-toggler-mobile-icon"><i class="far fa-bars"></i></span>
            </button>
          </div>

          <div class="collapse navbar-collapse" id="main_nav">
            <ul class="navbar-nav">
              {% for item in header_menu_items %}
                <li class="nav-item{% if item.below %} dropdown{% endif %}">
                  <a class="nav-link{% if item.below %} dropdown-toggle{% endif %}" href="{{ item.url }}"{% if item.below %} data-bs-toggle="dropdown"{% endif %}>{{ item.title|raw }}</a>
                  {% if item.below %}
                    {% include '@gprep_theme/includes/menu-links.html.twig' with {
                      items: item.below,
                      attributes: create_attribute({'class': ['dropdown-menu', 'fade-down']})
                    } only %}
                  {% endif %}
                </li>
              {% endfor %}
            </ul>
            <div class="nav-right">
              <div class="search-btn">
                <button type="button" class="nav-right-link"><i class="far fa-search"></i></button>
              </div>
              <div class="nav-right-call">
                <span class="call-icon"><i class="fal fa-phone-volume"></i></span>
                <div class="call-content">
                  <span>{{ gprep_settings.emergency_label }}</span>
                  <h5><a href="tel:{{ gprep_settings.emergency_phone_link }}">{{ gprep_settings.emergency_phone }}</a></h5>
                </div>
              </div>
            </div>
          </div>

          <div class="search-area">
            <form action="#">
              <div class="form-group">
                <input type="text" class="form-control" placeholder="Type Keyword...">
                <button type="submit" class="search-icon-btn"><i class="far fa-search"></i></button>
              </div>
            </form>
          </div>
        </div>
      </nav>
    </div>
  {% endif %}
</header>

{% set page_content = page.content|render %}

<main id="main-content" class="main">
  {% if show_emergency_homepage %}
    <section class="emergencySectionArea">
      <div class="container">
        <div class="emergencyArea">
          {% if homepage_banner_items %}
            <div class="breakingNewsArea mb-5">
              <div class="braking-inner">
                <div class="bracking-left">
                  <h2>Current Emergency</h2>
                </div>
                <div class="brack-text-rigt">
                  <ul class="gprep-emergency-marquee marquee_mode-left" aria-label="Current emergency updates">
                    {% for item in homepage_banner_items %}
                      <li>
                        {% if item.banner_prefix %}
                          <strong>{{ item.banner_prefix|replace({' -': ' -'}) }}</strong> {{ item.banner_message }}
                        {% else %}
                          {{ item.banner_message ?: item.title }}
                        {% endif %}
                      </li>
                    {% endfor %}
                    {% for item in homepage_banner_items %}
                      <li aria-hidden="true">
                        {% if item.banner_prefix %}
                          <strong>{{ item.banner_prefix|replace({' -': ' -'}) }}</strong> {{ item.banner_message }}
                        {% else %}
                          {{ item.banner_message ?: item.title }}
                        {% endif %}
                      </li>
                    {% endfor %}
                  </ul>
                  <div class="gprep-emergency-mobile-list" aria-label="Current emergency updates">
                    {% for item in homepage_banner_items %}
                      <div class="gprep-emergency-mobile-item">
                        {% if item.banner_prefix %}
                          <strong>{{ item.banner_prefix|replace({' -': ' -'}) }}</strong> {{ item.banner_message }}
                        {% else %}
                          {{ item.banner_message ?: item.title }}
                        {% endif %}
                      </div>
                    {% endfor %}
                  </div>
                </div>
              </div>
              <div class="cross"><i class="fa-regular fa-xmark"></i></div>
            </div>
          {% endif %}

          <div class="row">
            <div class="col-lg-8">
              <div class="emergencyHeadingArea">
                <h3><span><i class="fa-solid fa-hexagon-exclamation"></i> Incident Details</span></h3>
                <div class="row mt-5">
                  <div class="col-md-6">
                    <div class="emergencyBox">
                      <h4>Incident Type</h4>
                      <p>{{ emergency_primary_update.incident ?: 'Emergency Incident' }}</p>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="emergencyBox">
                      <h4>Incident Location</h4>
                      <p>County of Grande Prairie</p>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="emergencyBox">
                      <h4>Incident Status</h4>
                      <p>Active</p>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="emergencyBox">
                      <h4>Start Date</h4>
                      <p>{{ emergency_primary_update.display_date_long ?: 'To be updated' }}</p>
                    </div>
                  </div>
                </div>
                <div class="emergencyBoxDetails">
                  <h1>{{ emergency_page_settings.incident_title ?: emergency_primary_update.title ?: 'Emergency details will appear here.' }}</h1>
                  {% if emergency_page_settings.incident_body %}
                    <div>{{ emergency_page_settings.incident_body|raw }}</div>
                  {% elseif emergency_primary_update.summary %}
                    <div>{{ emergency_primary_update.summary|raw }}</div>
                  {% else %}
                    <p>Emergency information will replace the regular homepage when emergency mode is enabled.</p>
                  {% endif %}
                  {% if emergency_page_settings.incident_button_text and emergency_page_settings.incident_button_link %}
                    <a href="{{ emergency_page_settings.incident_button_link }}" class="btnPdf mt-3">{{ emergency_page_settings.incident_button_text }}</a>
                  {% endif %}
                </div>
              </div>
            </div>

            <div class="col-lg-4">
              <div class="newsRightSection">
                <div class="newsRightArea">
                  <h3><span>Emergency Updates</span></h3>
                  <ul class="marquee_mode" style="height: 380px;">
                    {% for item in homepage_emergency_updates|slice(0, 10) %}
                      <li data-hover="{{ item.title }}">
                        <a href="{{ item.url }}">
                          <span>{{ item.update_time }} · <span>{{ item.update_relative_time }}</span></span>
                          {{ item.title }}
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="emergencyResourcesSection tabDrsignArea">
      <div class="container">
        <div class="choos-us-style-one-items mt-120 mt-md-0 mt-xs-0">
          <div class="site-heading text-center mb-4">
            <h2 class="site-title">Resources</h2>
            <div class="heading-divider"></div>
          </div>
          <div class="emergencyResourcesBox">
            <div class="tab-style-two-items">
              <nav aria-label="Emergency resources navigation">
                <div class="nav nav-tabs gao-2" id="emergency-nav-tab" role="tablist">
                  <button class="nav-link active col" id="emergency-tab-1" data-bs-toggle="tab" data-bs-target="#emergency-pane-1" type="button" role="tab" aria-controls="emergency-pane-1" aria-selected="true">Alberta Emergency Alerts</button>
                  <button class="nav-link" style="width: 120px;" id="emergency-tab-2" data-bs-toggle="tab" data-bs-target="#emergency-pane-2" type="button" role="tab" aria-controls="emergency-pane-2" aria-selected="false">Map</button>
                  <button class="nav-link col" id="emergency-tab-3" data-bs-toggle="tab" data-bs-target="#emergency-pane-3" type="button" role="tab" aria-controls="emergency-pane-3" aria-selected="false">Evacuee Resources</button>
                  <button class="nav-link" style="width: 140px;" id="emergency-tab-4" data-bs-toggle="tab" data-bs-target="#emergency-pane-4" type="button" role="tab" aria-controls="emergency-pane-4" aria-selected="false">Donations</button>
                  <button class="nav-link col" id="emergency-tab-5" data-bs-toggle="tab" data-bs-target="#emergency-pane-5" type="button" role="tab" aria-controls="emergency-pane-5" aria-selected="false">Temporary Access</button>
                </div>
              </nav>
              <div class="tab-content" id="emergency-nav-tabContent">
                <div class="tab-pane fade show active" id="emergency-pane-1" role="tabpanel" aria-labelledby="emergency-tab-1">
                  <p>{{ emergency_page_settings.alert_intro ?: 'This alert feed area is reserved for Alberta Emergency Alert integration and public instructions.' }}</p>
                  <div class="alert alert-warning mt-4">
                    <strong>{{ emergency_page_settings.alert_feed_title ?: 'Emergency Alert Feed' }}</strong><br>
                    {{ emergency_page_settings.alert_feed_message ?: 'Connect the approved Alberta emergency alert source here in the next phase.' }}
                  </div>
                  <div class="alert alert-danger emergencyAlertDetail">
                    <h5 class="mb-2"><i class="fa-solid fa-light-emergency-on"></i> Active Emergency Alert</h5>
                    <p><strong>Type:</strong> {{ emergency_page_settings.alert_type ?: emergency_primary_update.incident ?: 'Emergency Incident' }}</p>
                    <p><strong>Affected Area:</strong> {{ emergency_page_settings.alert_area ?: 'County of Grande Prairie' }}</p>
                    <p><strong>Date & Time:</strong> {{ emergency_page_settings.alert_datetime ?: emergency_primary_update.display_date_long ?: 'To be updated' }}{% if not emergency_page_settings.alert_datetime and emergency_primary_update.display_time %} - {{ emergency_primary_update.display_time }}{% endif %}</p>
                    <p><strong>Instructions:</strong> {{ emergency_page_settings.alert_instructions ?: 'Follow official guidance and monitor the emergency updates panel for the latest information.' }}</p>
                  </div>
                </div>

                <div class="tab-pane fade" id="emergency-pane-2" role="tabpanel" aria-labelledby="emergency-tab-2">
                  <div class="mapArea p-1 mb-0">
                    {% if gprep_settings.map_embed_url %}
                      <iframe src="{{ gprep_settings.map_embed_url }}" title="Emergency map" style="border:1px solid #ccc; width: 100%; height: 700px; border-radius: 20px;" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                    {% endif %}
                  </div>
                </div>

                <div class="tab-pane fade" id="emergency-pane-3" role="tabpanel" aria-labelledby="emergency-tab-3">
                  <div class="evacueeResourcesArea">
                    <nav aria-label="Emergency resource category navigation">
                      <div class="nav nav-tabs gao-4 p-0" id="emergency-resource-tab" role="tablist">
                        <button class="nav-link active col" id="emergency-resource-support" data-bs-toggle="tab" data-bs-target="#emergency-resource-support-pane" type="button" role="tab" aria-controls="emergency-resource-support-pane" aria-selected="true">Evacuee Support Guide</button>
                        <button class="nav-link col" id="emergency-resource-reentry" data-bs-toggle="tab" data-bs-target="#emergency-resource-reentry-pane" type="button" role="tab" aria-controls="emergency-resource-reentry-pane" aria-selected="false">Re-entry Guide</button>
                        <button class="nav-link col" id="emergency-resource-recovery" data-bs-toggle="tab" data-bs-target="#emergency-resource-recovery-pane" type="button" role="tab" aria-controls="emergency-resource-recovery-pane" aria-selected="false">Recovery Guide</button>
                      </div>
                    </nav>
                    <div class="tab-content" id="emergency-resource-content">
                      <div class="tab-pane fade show active" id="emergency-resource-support-pane" role="tabpanel" aria-labelledby="emergency-resource-support">
                        <ul>
                          {% for item in emergency_resource_groups.support %}
                            <li class="align-items-center justify-content-between">
                              <p>{{ item.title }}</p>
                              <a href="{{ item.url }}" class="btnPdf">Open Resource</a>
                            </li>
                          {% endfor %}
                        </ul>
                      </div>
                      <div class="tab-pane fade" id="emergency-resource-reentry-pane" role="tabpanel" aria-labelledby="emergency-resource-reentry">
                        <ul>
                          {% for item in emergency_resource_groups.reentry %}
                            <li class="align-items-center justify-content-between">
                              <p>{{ item.title }}</p>
                              <a href="{{ item.url }}" class="btnPdf">Open Resource</a>
                            </li>
                          {% endfor %}
                        </ul>
                      </div>
                      <div class="tab-pane fade" id="emergency-resource-recovery-pane" role="tabpanel" aria-labelledby="emergency-resource-recovery">
                        <ul>
                          {% for item in emergency_resource_groups.recovery %}
                            <li class="align-items-center justify-content-between">
                              <p>{{ item.title }}</p>
                              <a href="{{ item.url }}" class="btnPdf">Open Resource</a>
                            </li>
                          {% endfor %}
                        </ul>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="tab-pane fade" id="emergency-pane-4" role="tabpanel" aria-labelledby="emergency-tab-4">
                  <div class="evacueeResourcesArea">
                    <h6>{{ emergency_page_settings.donations_heading ?: 'Support Our Cause Through Your Generous Donations' }}</h6>
                    <div class="donations-content">
                      <ul>
                        {% for item in emergency_page_settings.donation_items %}
                          <li class="align-items-center justify-content-between">
                            <p>{{ item.title }}</p>
                            <a href="{{ item.url ?: '#' }}" class="btnPdf">{{ item.button_text ?: 'Open' }}</a>
                          </li>
                        {% endfor %}
                      </ul>
                    </div>
                  </div>
                </div>

                <div class="tab-pane fade" id="emergency-pane-5" role="tabpanel" aria-labelledby="emergency-tab-5">
                  <h3 class="mb-3">{{ emergency_page_settings.temporary_access_title ?: emergency_primary_update.title ?: 'Temporary access information' }}</h3>
                  {% if emergency_page_settings.temporary_access_body %}
                    <div class="mb-3">{{ emergency_page_settings.temporary_access_body|raw }}</div>
                  {% elseif emergency_primary_update.summary %}
                    <div class="mb-3">{{ emergency_primary_update.summary|raw }}</div>
                  {% else %}
                    <p class="mb-3">Temporary access instructions will appear here in the next phase.</p>
                  {% endif %}
                  <a href="{{ emergency_page_settings.temporary_access_button_link ?: '/contact' }}" class="btnPdf">{{ emergency_page_settings.temporary_access_button_text ?: 'Contact GPREP' }}</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  {% elseif is_front_page %}
    <div class="hero-section">
      <div class="row m-0">
        <div class="col-lg-8 col-xl-8 col-xxl-9 p-0 position-relative">
          {% if homepage_banner_items %}
            <div class="breakingNesTopArea">
              <div class="breakingNewsArea">
                <div class="braking-inner">
                  <div class="bracking-left">
                    <h2>Current Emergency</h2>
                  </div>
                  <div class="brack-text-rigt">
                    <ul class="gprep-emergency-marquee" aria-label="Current emergency updates">
                      {% for item in homepage_banner_items %}
                        <li data-hover="{{ item.title }}">
                          {% if item.banner_prefix %}
                            <strong>{{ item.banner_prefix }}</strong> {{ item.banner_message }}
                          {% else %}
                            {{ item.banner_message ?: item.title }}
                          {% endif %}
                        </li>
                      {% endfor %}
                      {% for item in homepage_banner_items %}
                        <li data-hover="{{ item.title }}" aria-hidden="true">
                          {% if item.banner_prefix %}
                            <strong>{{ item.banner_prefix }}</strong> {{ item.banner_message }}
                          {% else %}
                            {{ item.banner_message ?: item.title }}
                          {% endif %}
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                </div>
                <div class="cross"><i class="fa-regular fa-xmark"></i></div>
              </div>
            </div>
          {% endif %}

          {% if homepage_hero_slides %}
            <div class="gprep-hero-slider owl-theme" data-autoplay-delay="5000">
              <div class="gprep-hero-slider-track">
              {% for slide in homepage_hero_slides %}
                <div class="hero-single gprep-hero-slide{% if loop.first %} is-active{% endif %}" data-slide-index="{{ loop.index0 }}"{% if slide.image_url %} style="background-image: url('{{ slide.image_url }}');"{% endif %}>
                  <div class="container">
                    <div class="row align-items-center">
                      <div class="col-md-12 col-lg-7">
                        <div class="hero-content">
                          <h1 class="hero-title" data-animation="fadeInRight" data-delay=".50s">
                            {{ slide.title }}
                          </h1>
                          {% if slide.description %}
                            <p data-animation="fadeInLeft" data-delay=".75s">
                              {{ slide.description|raw }}
                            </p>
                          {% endif %}
                          {% if slide.button_text and slide.button_link %}
                            <div class="hero-btn" data-animation="fadeInUp" data-delay="1s">
                              <a href="{{ slide.button_link }}" class="theme-btn">{{ slide.button_text }}<i class="fas fa-arrow-right"></i></a>
                            </div>
                          {% endif %}
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              {% endfor %}
              </div>
              {% if homepage_hero_slides|length > 1 %}
                <div class="owl-nav">
                  <button type="button" class="owl-prev" aria-label="Previous slide"><i class="far fa-long-arrow-left"></i></button>
                  <button type="button" class="owl-next" aria-label="Next slide"><i class="far fa-long-arrow-right"></i></button>
                </div>
                <div class="owl-dots">
                  {% for slide in homepage_hero_slides %}
                    <button type="button" class="owl-dot{% if loop.first %} active{% endif %}" aria-label="Go to slide {{ loop.index }}" data-slide-to="{{ loop.index0 }}"><span></span></button>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          {% endif %}
        </div>

        <div class="col-lg-4 col-xl-4 col-xxl-3 p-0">
          <div class="homenewsRightArea newsRightSection">
            <div class="newsRightArea">
              <h3><span>Emergency Updates</span></h3>
              <ul class="marquee_mode">
                {% for item in homepage_emergency_updates %}
                  <li data-hover="{{ item.title }}">
                    <a href="{{ item.url }}">
                      <span>{{ item.update_time }} · <span>{{ item.update_relative_time }}</span></span>
                      {{ item.title }}
                    </a>
                  </li>
                {% endfor %}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    {% if homepage_about_section %}
      <div class="about-area aboutSection pt-80 pb-80">
        <div class="container">
          <div class="row align-items-center">
            <div class="col-lg-6">
              <div class="about-left wow fadeInLeft" data-wow-delay=".25s">
                <div class="about-img">
                  {% if homepage_about_section.image_url %}
                    <img src="{{ homepage_about_section.image_url }}" alt="{{ homepage_about_section.image_alt ?: homepage_about_section.title }}">
                  {% endif %}
                </div>
              </div>
            </div>
            <div class="col-lg-6">
              <div class="about-right wow fadeInRight" data-wow-delay=".25s">
                <div class="site-heading mb-2">
                  {% if homepage_about_section.tagline %}
                    <span class="site-title-tagline">
                      <i class="far fa-user-police"></i>{{ homepage_about_section.tagline }}
                    </span>
                  {% endif %}
                  <h2 class="site-title">
                    {{ homepage_about_section.title }}
                  </h2>
                </div>
                {% if homepage_about_section.primary_body %}
                  <div class="gprep-home-about-body">
                    {{ homepage_about_section.primary_body|raw }}
                  </div>
                {% endif %}
                {% if homepage_about_section.secondary_heading %}
                  <h2 class="site-title mb-2 mt-3">
                    {{ homepage_about_section.secondary_heading }}
                  </h2>
                {% endif %}
                {% if homepage_about_section.secondary_body %}
                  <div class="gprep-home-about-body">
                    {{ homepage_about_section.secondary_body|raw }}
                  </div>
                {% endif %}
                {% if homepage_about_section.button_text and homepage_about_section.button_link %}
                  <a href="{{ homepage_about_section.button_link }}" class="theme-btn mt-4">{{ homepage_about_section.button_text }}<i class="fas fa-arrow-right"></i></a>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      </div>
    {% endif %}

    {% if homepage_enrolled_members_section and homepage_enrolled_members %}
      <div class="enrolled-members-area pt-80 pb-80">
        <div class="container">
          <div class="row">
            <div class="col-lg-12 mx-auto">
              <div class="site-heading text-center">
                <h2 class="site-title">{{ homepage_enrolled_members_section.title }}</h2>
                <div class="heading-divider"></div>
                {% if homepage_enrolled_members_section.primary_body %}
                  <div class="gprep-enrolled-intro">{{ homepage_enrolled_members_section.primary_body|raw }}</div>
                {% endif %}
              </div>
            </div>
          </div>
          <div class="row gprep-team-grid">
            {% for item in homepage_enrolled_members %}
              <div class="col-md-6 col-lg-3">
                <div class="team-item mb-0" data-wow-delay=".25s">
                  <div class="team-img">
                    {% if item.image_url %}
                      <img src="{{ item.image_url }}" alt="{{ item.image_alt ?: item.title }}">
                    {% endif %}
                  </div>
                  <div class="team-content">
                    <div class="team-bio">
                      <h5>{{ item.title }}</h5>
                      {% if item.person_role %}
                        <span>{{ item.person_role }}</span>
                      {% endif %}
                    </div>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
          {% if homepage_enrolled_members_section.button_text and homepage_enrolled_members_section.button_link %}
            <div class="text-center mt-4">
              <a href="{{ homepage_enrolled_members_section.button_link }}" class="theme-btn theme-btn2">{{ homepage_enrolled_members_section.button_text }}<i class="fas fa-arrow-right"></i></a>
            </div>
          {% endif %}
