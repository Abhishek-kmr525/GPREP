<header class="header">
  <div class="header-top">
    <div class="container">
      <div class="header-top-wrapper">
        <div class="header-top-left">
          <div class="header-top-contact">
            <ul>
              {% if gprep_settings.phone %}
                <li><a href="tel:{{ gprep_settings.phone_link }}"><i class="far fa-phone"></i> {{ gprep_settings.phone }}</a></li>
              {% endif %}
              {% if gprep_settings.email %}
                <li><a href="mailto:{{ gprep_settings.email }}"><i class="far fa-envelopes"></i> {{ gprep_settings.email }}</a></li>
              {% endif %}
              {% if gprep_settings.emergency_phone %}
                <li class="d-lg-none"><a href="tel:{{ gprep_settings.emergency_phone_link }}"><i class="far fa-phone"></i> {{ gprep_settings.emergency_label }} ({{ gprep_settings.emergency_phone }})</a></li>
              {% endif %}
            </ul>
          </div>
        </div>
        <div class="header-top-right">
          <div class="header-top-social">
            <span>Follow Us: </span>
            {% if gprep_settings.facebook_url %}
              <a href="{{ gprep_settings.facebook_url }}"><i class="fab fa-facebook-f"></i></a>
            {% endif %}
            {% if gprep_settings.twitter_url %}
              <a href="{{ gprep_settings.twitter_url }}"><i class="fab fa-x-twitter"></i></a>
            {% endif %}
          </div>
          <div class="dropdown languageArea">
            <button class="btn dropdown-toggle" type="button" id="dropdownMenuButton1" data-bs-toggle="dropdown" aria-expanded="false">
              {{ gprep_settings.language_label }}
            </button>
            <ul class="dropdown-menu" aria-labelledby="dropdownMenuButton1">
              <li><a class="dropdown-item" href="#">English</a></li>
              <li><a class="dropdown-item" href="#">French</a></li>
              <li><a class="dropdown-item" href="#">Spanish</a></li>
              <li><a class="dropdown-item" href="#">Italian</a></li>
              <li><a class="dropdown-item" href="#">German</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="main-navigation">
    <nav class="navbar navbar-expand-lg">
      <div class="container position-relative">
        <a class="navbar-brand" href="{{ front_page }}">
          <img src="{{ theme_path }}/assets/img/logo/logo-light.png" class="logo-display" alt="GPREP logo">
          <img src="{{ theme_path }}/assets/img/logo/logo.png" class="logo-scrolled" alt="GPREP logo">
        </a>

        <div class="mobile-menu-right">
          <div class="search-btn">
            <button type="button" class="nav-right-link"><i class="far fa-search"></i></button>
          </div>
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#main_nav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-mobile-icon"><i class="far fa-bars"></i></span>
          </button>
        </div>

        <div class="collapse navbar-collapse" id="main_nav">
          <ul class="navbar-nav">
            {% for item in header_menu_items %}
              <li class="nav-item{% if item.below %} dropdown{% endif %}">
                <a class="nav-link{% if item.below %} dropdown-toggle{% endif %}" href="{{ item.url }}"{% if item.below %} data-bs-toggle="dropdown"{% endif %}>{{ item.title|raw }}</a>
                {% if item.below %}
                  {% include '@gprep_theme/includes/menu-links.html.twig' with {
                    items: item.below,
                    attributes: create_attribute({'class': ['dropdown-menu', 'fade-down']})
                  } only %}
                {% endif %}
              </li>
            {% endfor %}
          </ul>
          <div class="nav-right">
            <div class="search-btn">
              <button type="button" class="nav-right-link"><i class="far fa-search"></i></button>
            </div>
            <div class="nav-right-call">
              <span class="call-icon"><i class="fal fa-phone-volume"></i></span>
              <div class="call-content">
                <span>{{ gprep_settings.emergency_label }}</span>
                <h5><a href="tel:{{ gprep_settings.emergency_phone_link }}">{{ gprep_settings.emergency_phone }}</a></h5>
              </div>
            </div>
          </div>
        </div>

        <div class="search-area">
          <form action="#">
            <div class="form-group">
              <input type="text" class="form-control" placeholder="Type Keyword...">
              <button type="submit" class="search-icon-btn"><i class="far fa-search"></i></button>
            </div>
          </form>
        </div>
      </div>
    </nav>
  </div>
</header>

{% set page_content = page.content|render %}

<main id="main-content" class="main">
  {% if is_front_page %}
    <div class="hero-section">
      <div class="row m-0">
        <div class="col-lg-8 col-xl-8 col-xxl-9 p-0 position-relative">
          {% if homepage_banner_items %}
            <div class="breakingNesTopArea">
              <div class="breakingNewsArea">
                <div class="braking-inner">
                  <div class="bracking-left">
                    <h2>Current Emergency</h2>
                  </div>
                  <div class="brack-text-rigt">
                    <ul class="gprep-emergency-marquee" aria-label="Current emergency updates">
                      {% for item in homepage_banner_items %}
                        <li data-hover="{{ item.title }}">
                          {% if item.banner_prefix %}
                            <strong>{{ item.banner_prefix }}</strong> {{ item.banner_message }}
                          {% else %}
                            {{ item.banner_message ?: item.title }}
                          {% endif %}
                        </li>
                      {% endfor %}
                      {% for item in homepage_banner_items %}
                        <li data-hover="{{ item.title }}" aria-hidden="true">
                          {% if item.banner_prefix %}
                            <strong>{{ item.banner_prefix }}</strong> {{ item.banner_message }}
                          {% else %}
                            {{ item.banner_message ?: item.title }}
                          {% endif %}
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                </div>
                <div class="cross"><i class="fa-regular fa-xmark"></i></div>
              </div>
            </div>
          {% endif %}

          {% if homepage_hero_slides %}
            <div class="gprep-hero-slider owl-theme" data-autoplay-delay="5000">
              <div class="gprep-hero-slider-track">
              {% for slide in homepage_hero_slides %}
                <div class="hero-single gprep-hero-slide{% if loop.first %} is-active{% endif %}" data-slide-index="{{ loop.index0 }}"{% if slide.image_url %} style="background-image: url('{{ slide.image_url }}');"{% endif %}>
                  <div class="container">
                    <div class="row align-items-center">
                      <div class="col-md-12 col-lg-7">
                        <div class="hero-content">
                          <h1 class="hero-title" data-animation="fadeInRight" data-delay=".50s">
                            {{ slide.title }}
                          </h1>
                          {% if slide.description %}
                            <p data-animation="fadeInLeft" data-delay=".75s">
                              {{ slide.description|raw }}
                            </p>
                          {% endif %}
                          {% if slide.button_text and slide.button_link %}
                            <div class="hero-btn" data-animation="fadeInUp" data-delay="1s">
                              <a href="{{ slide.button_link }}" class="theme-btn">{{ slide.button_text }}<i class="fas fa-arrow-right"></i></a>
                            </div>
                          {% endif %}
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              {% endfor %}
              </div>
              {% if homepage_hero_slides|length > 1 %}
                <div class="owl-nav">
                  <button type="button" class="owl-prev" aria-label="Previous slide"><i class="far fa-long-arrow-left"></i></button>
                  <button type="button" class="owl-next" aria-label="Next slide"><i class="far fa-long-arrow-right"></i></button>
                </div>
                <div class="owl-dots">
                  {% for slide in homepage_hero_slides %}
                    <button type="button" class="owl-dot{% if loop.first %} active{% endif %}" aria-label="Go to slide {{ loop.index }}" data-slide-to="{{ loop.index0 }}"><span></span></button>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          {% endif %}
        </div>

        <div class="col-lg-4 col-xl-4 col-xxl-3 p-0">
          <div class="homenewsRightArea newsRightSection">
            <div class="newsRightArea">
              <h3><span>Emergency Updates</span></h3>
              <ul class="marquee_mode">
                {% for item in homepage_emergency_updates %}
                  <li data-hover="{{ item.title }}">
                    <a href="{{ item.url }}">
                      <span>{{ item.update_time }} · <span>{{ item.update_relative_time }}</span></span>
                      {{ item.title }}
                    </a>
                  </li>
                {% endfor %}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    {% if homepage_about_section %}
      <div class="about-area aboutSection pt-80 pb-80">
        <div class="container">
          <div class="row align-items-center">
            <div class="col-lg-6">
              <div class="about-left wow fadeInLeft" data-wow-delay=".25s">
                <div class="about-img">
                  {% if homepage_about_section.image_url %}
                    <img src="{{ homepage_about_section.image_url }}" alt="{{ homepage_about_section.title }}">
                  {% endif %}
                </div>
              </div>
            </div>
            <div class="col-lg-6">
              <div class="about-right wow fadeInRight" data-wow-delay=".25s">
                <div class="site-heading mb-2">
                  {% if homepage_about_section.tagline %}
                    <span class="site-title-tagline">
                      <i class="far fa-user-police"></i>{{ homepage_about_section.tagline }}
                    </span>
                  {% endif %}
                  <h2 class="site-title">
                    {{ homepage_about_section.title }}
                  </h2>
                </div>
                {% if homepage_about_section.primary_body %}
                  <div class="gprep-home-about-body">
                    {{ homepage_about_section.primary_body|raw }}
                  </div>
                {% endif %}
                {% if homepage_about_section.secondary_heading %}
                  <h2 class="site-title mb-2 mt-3">
                    {{ homepage_about_section.secondary_heading }}
                  </h2>
                {% endif %}
                {% if homepage_about_section.secondary_body %}
                  <div class="gprep-home-about-body">
                    {{ homepage_about_section.secondary_body|raw }}
                  </div>
                {% endif %}
                {% if homepage_about_section.button_text and homepage_about_section.button_link %}
                  <a href="{{ homepage_about_section.button_link }}" class="theme-btn mt-4">{{ homepage_about_section.button_text }}<i class="fas fa-arrow-right"></i></a>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      </div>
    {% endif %}

    {% if homepage_enrolled_members_section and homepage_enrolled_members %}
      <div class="enrolled-members-area pt-80 pb-80">
        <div class="container">
          <div class="row">
            <div class="col-lg-12 mx-auto">
              <div class="site-heading text-center">
                <h2 class="site-title">{{ homepage_enrolled_members_section.title }}</h2>
                <div class="heading-divider"></div>
                {% if homepage_enrolled_members_section.primary_body %}
                  <div class="gprep-enrolled-intro">{{ homepage_enrolled_members_section.primary_body|raw }}</div>
                {% endif %}
              </div>
            </div>
          </div>
          <div class="row gprep-team-grid">
            {% for item in homepage_enrolled_members %}
              <div class="col-md-6 col-lg-3">
                <div class="team-item mb-0" data-wow-delay=".25s">
                  <div class="team-img">
                    {% if item.image_url %}
                      <img src="{{ item.image_url }}" alt="{{ item.title }}">
                    {% endif %}
                  </div>
                  <div class="team-content">
                    <div class="team-bio">
                      <h5>{{ item.title }}</h5>
                      {% if item.person_role %}
                        <span>{{ item.person_role }}</span>
                      {% endif %}
                    </div>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
          {% if homepage_enrolled_members_section.button_text and homepage_enrolled_members_section.button_link %}
            <div class="text-center mt-4">
              <a href="{{ homepage_enrolled_members_section.button_link }}" class="theme-btn theme-btn2">{{ homepage_enrolled_members_section.button_text }}<i class="fas fa-arrow-right"></i></a>
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if homepage_stakeholders_section and homepage_stakeholder_items %}
      <div class="team-area pt-80 pb-40">
        <div class="container">
          <div class="row">
            <div class="col-lg-12 mx-auto">
              <div class="site-heading text-center">
                <h2 class="site-title">{{ homepage_stakeholders_section.title }}</h2>
                <div class="heading-divider"></div>
                {% if homepage_stakeholders_section.primary_body %}
                  <div class="gprep-stakeholder-intro">{{ homepage_stakeholders_section.primary_body|raw }}</div>
                {% endif %}
              </div>
            </div>
          </div>
          <div class="row gprep-team-grid">
            {% for item in homepage_stakeholder_items %}
              <div class="col-md-6 col-lg-3">
                <div class="team-item mb-0" data-wow-delay=".25s">
                  <div class="team-img">
                    {% if item.image_url %}
                      <img src="{{ item.image_url }}" alt="{{ item.title }}">
                    {% endif %}
                  </div>
                  <div class="team-content">
                    <div class="team-bio">
                      <h5>{{ item.title }}</h5>
                      {% if item.person_role %}
                        <span>{{ item.person_role }}</span>
                      {% endif %}
                    </div>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    {% endif %}

    {% if homepage_partner_municipalities %}
      <div class="partner-area pt-50 pb-50">
        <div class="container">
          <div class="gprep-partner-shell">
            <div class="row">
              <div class="col-lg-9 mx-auto">
                <div class="site-heading text-center mb-2">
                  <h2 class="site-title">{{ homepage_partner_section.title ?: 'Partner Municipalities' }}</h2>
                  <div class="heading-divider"></div>
                </div>
              </div>
            </div>
            <div class="partner-wrapper gprep-partner-grid">
              {% for item in homepage_partner_municipalities %}
                <a href="{{ item.partner_url ?: '#' }}"{% if item.partner_url %} target="_blank" rel="noopener noreferrer"{% endif %}>
                  <img src="{{ item.image_url }}" alt="{{ item.title }}">
                </a>
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
    {% endif %}

    {% if homepage_resource_items %}
      <div class="service-area bg pt-80 pb-80">
        <div class="container">
          <div class="row">
            <div class="col-lg-7 mx-auto">
              <div class="site-heading text-center">
                <h2 class="site-title">{{ homepage_resources_section.title ?: 'Resources' }}</h2>
                <div class="heading-divider"></div>
              </div>
            </div>
          </div>
          <div class="row">
            {% for item in homepage_resource_items %}
              <div class="col-md-6 col-lg-4">
                <div class="service-item wow fadeInUp" data-wow-delay=".25s">
                  <div class="service-img-wrap">
                    <div class="service-img">
                      {% if item.image_url %}
                        <img src="{{ item.image_url }}" alt="{{ item.title }}">
                      {% endif %}
                    </div>
                  </div>
                  <div class="service-content">
                    {% if item.icon_image_url %}
                      <div class="service-icon">
                        <img src="{{ item.icon_image_url }}" alt="{{ item.title }}">
                      </div>
                    {% endif %}
                    <h3 class="service-title">
                      <a href="{{ item.button_link ?: item.url }}">{{ item.title }}</a>
                    </h3>
                    {% if item.summary %}
                      <div class="service-text">{{ item.summary|raw }}</div>
                    {% endif %}
                    <div class="service-arrow">
                      <a href="{{ item.button_link ?: item.url }}" class="theme-btn">{{ item.button_text ?: 'Read More' }}<i class="fas fa-arrow-right"></i></a>
                    </div>
                  </div>
                </div>
              </div>
            {% endfor %}
            {% if homepage_resources_section.button_text and homepage_resources_section.button_link %}
              <div class="text-center">
                <a href="{{ homepage_resources_section.button_link }}" class="theme-btn mt-4">{{ homepage_resources_section.button_text }}<i class="fas fa-arrow-right"></i></a>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    {% endif %}

    {% if homepage_faq_section and homepage_faq_items %}
      <div class="faq-area homeFaqArea py-120">
        <div class="container">
          <div class="row">
            <div class="col-lg-5">
              <div class="faq-right pe-5">
                <div class="site-heading mb-3">
                  {% if homepage_faq_section.tagline %}
                    <span class="site-title-tagline justify-content-start"><i class="far fa-fire-flame-curved"></i>{{ homepage_faq_section.tagline }}</span>
                  {% endif %}
                  <h2 class="site-title my-3">{{ homepage_faq_section.title|raw }}</h2>
                </div>
                {% if homepage_faq_section.primary_body %}
                  <div class="gprep-home-faq-body mb-3">{{ homepage_faq_section.primary_body|raw }}</div>
                {% endif %}
                {% if homepage_faq_section.button_text and homepage_faq_section.button_link %}
                  <a href="{{ homepage_faq_section.button_link }}" class="theme-btn mt-2">{{ homepage_faq_section.button_text }}</a>
                {% endif %}
              </div>
            </div>
            <div class="col-lg-7">
              {% if homepage_faq_section.secondary_heading %}
                <h3 class="mb-4">{{ homepage_faq_section.secondary_heading }}</h3>
              {% endif %}
              <div class="accordion" id="homepageFaqAccordion">
                {% for item in homepage_faq_items %}
                  <div class="accordion-item">
                    <h2 class="accordion-header" id="homepageFaqHeading{{ loop.index }}">
                      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#homepageFaqCollapse{{ loop.index }}" aria-expanded="false" aria-controls="homepageFaqCollapse{{ loop.index }}">
                        <span><i class="far fa-question"></i></span> {{ item.title }}
                      </button>
                    </h2>
                    <div id="homepageFaqCollapse{{ loop.index }}" class="accordion-collapse collapse" aria-labelledby="homepageFaqHeading{{ loop.index }}" data-bs-parent="#homepageFaqAccordion">
                      <div class="accordion-body">{{ item.answer_body|raw }}</div>
                    </div>
                  </div>
                {% endfor %}
              </div>
            </div>
          </div>
        </div>
      </div>
    {% endif %}

    <div class="feature-area feature-bg py-120">
      <div class="container">
        <div class="feature-wrapper mt-5">
          <div class="row">
            <div class="col-md-6 col-lg-3">
              <div class="feature-item wow fadeInUp p-3 mb-3" data-wow-delay=".25s">
                <h4 class="feature-title mb-0">Be Prepared</h4>
                <p class="mb-2"><strong>Alberta</strong></p>
                <div class="text-center">
                  <a href="https://www.alberta.ca/emergency-preparedness?utm_source=redirect&amp;utm_medium=poster&amp;utm_campaign=GoA&amp;utm_term=BePrepared" target="_blank" rel="noopener noreferrer" class="theme-btn mt-0 py-2 rounded-5">Read More<i class="fas fa-arrow-right"></i></a>
                </div>
              </div>
              <div class="feature-item wow fadeInDown p-3" data-wow-delay=".25s">
                <h4 class="feature-title mb-0">Get Prepared</h4>
                <p class="mb-2"><strong>Canada</strong></p>
                <div class="text-center">
                  <a href="https://www.canada.ca/en/services/policing/emergencies/preparedness/get-prepared.html" target="_blank" rel="noopener noreferrer" class="theme-btn py-2 rounded-5">Read More<i class="fas fa-arrow-right"></i></a>
                </div>
              </div>
            </div>
            <div class="col-md-6 col-lg-3">
              <div class="feature-item wow fadeInDown px-3" data-wow-delay=".25s">
                <div class="feature-icon">
                  <img src="{{ theme_path }}/assets/img/icon/ab_icon.png" alt="AB Wildfire Status">
                </div>
                <h4 class="feature-title mb-0">AB Wildfire Status</h4>
                <p class="mb-2"><strong>APP</strong></p>
                <p>Download the app</p>
                <div class="text-center">
                  <a href="https://play.google.com/store/apps/details?id=com.ab.wildfire" target="_blank" rel="noopener noreferrer" class="theme-btn mt-3 py-2" style="background: #000; width: 100%;"><img src="{{ theme_path }}/assets/img/icon/google_play_store.png" style="width: 18px; margin-right: 5px;" alt=""> Google Play Store</a>
                  <a href="https://apps.apple.com/ca/app/ab-wildfire-status/id1554525514" target="_blank" rel="noopener noreferrer" class="theme-btn py-2" style="background: #000; width: 100%;"><img src="{{ theme_path }}/assets/img/icon/apple_play_store.png" style="width: 18px; margin-right: 5px;" alt=""> Apple App Store</a>
                </div>
              </div>
            </div>
            <div class="col-md-6 col-lg-6">
              <div class="feature-item wow fadeInUp" data-wow-delay=".25s">
                <div class="feature-icon">
                  <img src="{{ theme_path }}/assets/img/icon/ae_icon.png" alt="Alberta Emergency Alert">
                </div>
                <div class="d-block d-md-flex gap-4 align-items-center">
                  <div class="col-5 p-0">
                    <img src="{{ theme_path }}/assets/img/02.jpg" style="width: 100%;" alt="Alberta Emergency Alert">
                  </div>
                  <div class="col text-start">
                    <h4 class="feature-title">Alberta Emergency Alert</h4>
                    <p>Visit the <strong>Alberta Emergency Alert website</strong> for more information, or to <strong>download the app.</strong></p>
                  </div>
                </div>
                <div>
                  <a href="https://play.google.com/store/apps/details?id=ca.ab.gov.aea" target="_blank" rel="noopener noreferrer" class="theme-btn mt-3 py-2" style="background: #000;"><img src="{{ theme_path }}/assets/img/icon/google_play_store.png" style="width: 18px; margin-right: 5px;" alt=""> Google Play Store</a>
                  <a href="https://apps.apple.com/ca/app/alberta-emergency-alert/id887604348" target="_blank" rel="noopener noreferrer" class="theme-btn py-2" style="background: #000;"><img src="{{ theme_path }}/assets/img/icon/apple_play_store.png" style="width: 18px; margin-right: 5px;" alt=""> Apple App Store</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    {% if homepage_news_section and homepage_news_items %}
      <div class="campaign-area bg py-120">
        <div class="container">
          <div class="row">
            <div class="col-lg-6 mx-auto">
              <div class="site-heading text-center">
                <h2 class="site-title">{{ homepage_news_section.title|raw }}</h2>
                <div class="heading-divider"></div>
              </div>
            </div>
          </div>
          <div class="row">
            {% for item in homepage_news_items %}
              <div class="col-md-6 col-lg-4">
                <div class="campaign-item wow fadeInUp" data-wow-delay=".25s">
                  <div class="campaign-date">
                    <span class="campaign-date-day">{{ item.date_day }}</span><span class="campaign-date-month">{{ item.date_month }}</span>
                  </div>
                  <div class="campaign-img">
                    {% if item.image_url %}
                      <img src="{{ item.image_url }}" alt="{{ item.title }}">
                    {% endif %}
                  </div>
                  <div class="campaign-content">
                    <h4 class="campaign-title">
                      <a href="{{ item.button_link ?: item.url }}">{{ item.title }}</a>
                    </h4>
                    {% if item.summary %}
                      <div class="campaign-text">{{ item.summary|raw }}</div>
                    {% endif %}
                    <div class="campaign-footer mt-4">
                      <a href="{{ item.button_link ?: item.url }}" class="theme-btn">{{ item.button_text ?: 'Read More' }}<i class="fas fa-arrow-right"></i></a>
                    </div>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    {% endif %}

    <div class="cta-area mt-0">
      <div class="cta-wrapper" style="background-image: url('{{ theme_path }}/assets/img/cta/01.jpg');">
        <div class="container">
