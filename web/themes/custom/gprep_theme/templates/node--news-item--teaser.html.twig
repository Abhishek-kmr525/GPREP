<div class="col-md-6 col-lg-4">
  <div class="campaign-item wow fadeInUp" data-wow-delay=".25s">
    <div class="campaign-date">
      <span class="campaign-date-day">{{ gprep_item.date_day }}</span><span class="campaign-date-month">{{ gprep_item.date_month }}</span>
    </div>
    <div class="campaign-img">
      {% if gprep_item.image_url %}
        <img src="{{ gprep_item.image_url }}" alt="{{ gprep_item.title }}">
      {% endif %}
    </div>
    <div class="campaign-content">
      <h4 class="campaign-title">
        <a href="{{ gprep_item.button_link ?: gprep_item.url }}">{{ gprep_item.title }}</a>
      </h4>
      {% if gprep_item.summary %}
        <div class="campaign-text">{{ gprep_item.summary|raw }}</div>
      {% endif %}
      <div class="campaign-footer mt-4">
        <a href="{{ gprep_item.button_link ?: gprep_item.url }}" class="theme-btn">{{ gprep_item.button_text ?: 'Read More' }}<i class="fas fa-arrow-right"></i></a>
      </div>
    </div>
  </div>
</div>
