/**
 * Creates Drupal Views for repeatable homepage sections.
 */
function gprep_homepage_manager_update_11006(): void {
  $definitions = [
    'gprep_partner_municipalities' => [
      'label' => 'GPREP Partner Municipalities',
      'bundle' => 'partner_municipality',
      'items_per_page' => 20,
      'sorts' => [
        'field_display_order_value' => 'ASC',
        'created' => 'DESC',
      ],
    ],
    'gprep_homepage_resources' => [
      'label' => 'GPREP Homepage Resources',
      'bundle' => 'resource_item',
      'items_per_page' => 6,
      'sorts' => [
        'field_display_order_value' => 'ASC',
        'created' => 'DESC',
      ],
    ],
    'gprep_homepage_faq' => [
      'label' => 'GPREP Homepage FAQ',
      'bundle' => 'faq_item',
      'items_per_page' => 10,
      'sorts' => [
        'field_display_order_value' => 'ASC',
        'created' => 'DESC',
      ],
    ],
    'gprep_homepage_enrolled_members' => [
      'label' => 'GPREP Homepage Enrolled Members',
      'bundle' => 'enrolled_member',
      'items_per_page' => 8,
      'sorts' => [
        'field_display_order_value' => 'ASC',
        'created' => 'DESC',
      ],
    ],
    'gprep_homepage_stakeholders' => [
      'label' => 'GPREP Homepage Stakeholders',
      'bundle' => 'stakeholder_item',
      'items_per_page' => 8,
      'sorts' => [
        'field_display_order_value' => 'ASC',
        'created' => 'DESC',
      ],
    ],
    'gprep_homepage_news' => [
      'label' => 'GPREP Homepage News',
      'bundle' => 'news_item',
      'items_per_page' => 3,
      'sorts' => [
        'created' => 'DESC',
      ],
    ],
  ];

  foreach ($definitions as $view_id => $definition) {
    _gprep_homepage_manager_ensure_node_view(
      $view_id,
      $definition['label'],
      $definition['bundle'],
      $definition['items_per_page'],
      $definition['sorts']
    );
  }

  if ($test_view = View::load('gprep_test_view')) {
    $test_view->delete();
  }
}

