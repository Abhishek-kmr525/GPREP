/**
 * Creates admin form layouts for incident and emergency-related models.
 */
function gprep_homepage_manager_update_11009(): void {
  _gprep_homepage_manager_ensure_form_display('incident_type', [
    'title' => ['type' => 'string_textfield', 'weight' => 0, 'settings' => ['size' => 60, 'placeholder' => 'Incident type name']],
  ]);

  if ($field = FieldConfig::loadByName('node', 'news_item', 'field_incident')) {
    $field->setDescription('Select the incident type that this news item belongs to. This is used for filtering and emergency-related publishing flows.');
    $field->save();
  }
}

