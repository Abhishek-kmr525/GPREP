/**
 * Implements hook_install().
 */
function gprep_homepage_manager_install(): void {
  $types = [
    'hero_slide' => 'Hero Slide',
    'emergency_banner_item' => 'Emergency Banner Item',
    'emergency_update' => 'Emergency Update',
    'homepage_about_section' => 'Homepage About Section',
    'homepage_partner_section' => 'Homepage Partner Section',
    'partner_municipality' => 'Partner Municipality',
    'homepage_resources_section' => 'Homepage Resources Section',
    'resource_item' => 'Resource Item',
    'homepage_faq_section' => 'Homepage FAQ Section',
    'faq_item' => 'FAQ Item',
    'home_enrolled_section' => 'Homepage Enrolled Members Section',
    'enrolled_member' => 'Enrolled Member',
    'home_stakeholder_section' => 'Homepage Stakeholders Section',
    'stakeholder_item' => 'Stakeholder Item',
    'home_news_section' => 'Homepage News Section',
    'news_item' => 'News Item',
  ];

  foreach ($types as $machine_name => $label) {
    if (!NodeType::load($machine_name)) {
      NodeType::create([
        'type' => $machine_name,
        'name' => $label,
      ])->save();
    }
  }

  _gprep_homepage_manager_add_integer_field('field_display_order', 'Display Order', ['hero_slide', 'emergency_banner_item', 'emergency_update']);
  _gprep_homepage_manager_add_string_field('field_button_text', 'Button Text', ['hero_slide'], 255);
  _gprep_homepage_manager_add_link_field('field_button_link', 'Button Link', ['hero_slide']);
  _gprep_homepage_manager_add_text_long_field('field_slide_description', 'Slide Description', ['hero_slide']);
  _gprep_homepage_manager_add_image_field('field_slide_image', 'Slide Image', ['hero_slide']);
  _gprep_homepage_manager_add_string_field('field_update_time', 'Update Time', ['emergency_update'], 255);
  _gprep_homepage_manager_add_string_field('field_update_relative_time', 'Relative Time', ['emergency_update'], 255);
  _gprep_homepage_manager_add_link_field('field_update_link', 'Update Link', ['emergency_update']);
  _gprep_homepage_manager_add_string_field('field_section_tagline', 'Section Tagline', ['homepage_about_section'], 255);
  _gprep_homepage_manager_add_string_field('field_secondary_heading', 'Secondary Heading', ['homepage_about_section'], 255);
  _gprep_homepage_manager_add_text_long_field('field_primary_body', 'Primary Body', ['homepage_about_section']);
  _gprep_homepage_manager_add_text_long_field('field_secondary_body', 'Secondary Body', ['homepage_about_section']);
  _gprep_homepage_manager_add_image_field('field_section_image', 'Section Image', ['homepage_about_section']);
  _gprep_homepage_manager_add_string_field('field_button_text', 'Button Text', ['homepage_about_section'], 255);
  _gprep_homepage_manager_add_link_field('field_button_link', 'Button Link', ['homepage_about_section']);
  _gprep_homepage_manager_add_integer_field('field_display_order', 'Display Order', ['partner_municipality', 'resource_item', 'faq_item']);
  _gprep_homepage_manager_add_string_field('field_section_tagline', 'Section Tagline', ['homepage_faq_section'], 255);
  _gprep_homepage_manager_add_string_field('field_secondary_heading', 'Secondary Heading', ['homepage_faq_section'], 255);
  _gprep_homepage_manager_add_text_long_field('field_primary_body', 'Primary Body', ['homepage_faq_section']);
  _gprep_homepage_manager_add_string_field('field_button_text', 'Button Text', ['homepage_resources_section', 'homepage_faq_section', 'resource_item'], 255);
  _gprep_homepage_manager_add_link_field('field_button_link', 'Button Link', ['homepage_resources_section', 'homepage_faq_section', 'resource_item']);
  _gprep_homepage_manager_add_image_field('field_logo_image', 'Logo Image', ['partner_municipality']);
  _gprep_homepage_manager_add_link_field('field_partner_url', 'Partner URL', ['partner_municipality']);
  _gprep_homepage_manager_add_image_field('field_card_image', 'Card Image', ['resource_item']);
  _gprep_homepage_manager_add_image_field('field_icon_image', 'Icon Image', ['resource_item']);
  _gprep_homepage_manager_add_text_long_field('field_resource_summary', 'Resource Summary', ['resource_item']);
  _gprep_homepage_manager_add_text_long_field('field_resource_body', 'Resource Detail Content', ['resource_item']);
  _gprep_homepage_manager_add_text_long_field('field_answer_body', 'Answer Body', ['faq_item']);
  _gprep_homepage_manager_add_text_long_field('field_primary_body', 'Primary Body', ['home_enrolled_section', 'home_stakeholder_section']);
  _gprep_homepage_manager_add_string_field('field_button_text', 'Button Text', ['home_enrolled_section', 'home_stakeholder_section', 'news_item'], 255);
  _gprep_homepage_manager_add_link_field('field_button_link', 'Button Link', ['home_enrolled_section', 'home_stakeholder_section', 'news_item']);
  _gprep_homepage_manager_add_integer_field('field_display_order', 'Display Order', ['enrolled_member', 'stakeholder_item', 'news_item']);
  _gprep_homepage_manager_add_string_field('field_person_role', 'Designation', ['enrolled_member', 'stakeholder_item'], 255);
  _gprep_homepage_manager_add_image_field('field_profile_image', 'Profile Image', ['enrolled_member', 'stakeholder_item']);
  _gprep_homepage_manager_add_string_field('field_display_date', 'Display Date', ['news_item'], 50);
  _gprep_homepage_manager_add_image_field('field_card_image', 'Card Image', ['news_item']);
  _gprep_homepage_manager_add_text_long_field('field_resource_summary', 'Summary', ['news_item']);
}

