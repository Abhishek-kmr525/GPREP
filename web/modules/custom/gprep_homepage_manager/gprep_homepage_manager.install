      <div class="col-md-6 our-security-two_col3">
        <div class="our-security-two_right">
          <h2 class="heading_title mb-3">Who is GPREP?</h2>
          <p><strong>GPREP</strong> is comprised of and funded by five municipalities, they are the:</p>
          <ul class="list-group list-group-borderless mb-4">
            <li class="list-group-item">
              <i class="fa fa-square-full"></i>
              <span class="pbmit-icon-list-text">City of Grande Prairie</span>
            </li>
            <li class="list-group-item">
              <i class="fa fa-square-full"></i>
              <span class="pbmit-icon-list-text">County of Grande Prairie</span>
            </li>
            <li class="list-group-item">
              <i class="fa fa-square-full"></i>
              <span class="pbmit-icon-list-text">Towns of Beaverlodge, Sexsmith and Wembley</span>
            </li>
          </ul>
          <h2 class="heading_title mb-3">Our Responsibility</h2>
          <p><strong>GPREP</strong> prepares municipalities by coordinating emergency response exercises and providing training opportunities.</p>
          <p><strong>GPREP</strong> responds to disasters by bringing together key players and establishing a control center to support first responders, and plan and coordinate the emergency response.</p>
          <div>
            <a href="/about" class="theme-btn mt-4">Read More<i class="fas fa-arrow-right"></i></a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
HTML;

  $app_block = _gprep_homepage_manager_ensure_basic_block('Homepage App Section', $app_body);
  $cta_block = _gprep_homepage_manager_ensure_basic_block('Homepage CTA Section', $cta_body);
  $who_block = _gprep_homepage_manager_ensure_basic_block('Homepage Who Is GPREP Section', $who_body);

  _gprep_homepage_manager_place_block('gprep_theme_homepage_app_section', $app_block->uuid(), 'homepage_app_section');
  _gprep_homepage_manager_place_block('gprep_theme_homepage_cta_section', $cta_block->uuid(), 'homepage_cta_section');
  _gprep_homepage_manager_place_block('gprep_theme_homepage_who_section', $who_block->uuid(), 'homepage_who_is_gprep_section');
}

/**
 * Creates client-safe editorial roles and guardrail permissions.
 */
function gprep_homepage_manager_update_11013(): void {
  $editor_permissions = [
    'access administration pages',
    'access content',
    'access content overview',
    'access gprep editorial dashboard',
    'access toolbar',
    'use text format basic_html',
    'view own unpublished content',
  ];
  $editor_bundles = [
    'news_item',
    'faq_item',
    'resource_item',
    'incident_type',
    'partner_municipality',
    'enrolled_member',
    'stakeholder_item',
  ];
  foreach ($editor_bundles as $bundle) {
    $editor_permissions = array_merge($editor_permissions, [
      "create {$bundle} content",
      "edit any {$bundle} content",
      "delete any {$bundle} content",
    ]);
  }

  $site_manager_permissions = array_merge($editor_permissions, [
    'administer gprep site settings',
    'create and edit custom blocks',
    'edit any basic block content',
    'delete any basic block content',
  ]);
  $site_manager_bundles = [
    'hero_slide',
    'emergency_banner_item',
    'homepage_about_section',
    'homepage_partner_section',
    'homepage_resources_section',
    'homepage_faq_section',
    'home_enrolled_section',
    'home_stakeholder_section',
    'home_news_section',
  ];
  foreach ($site_manager_bundles as $bundle) {
    $site_manager_permissions = array_merge($site_manager_permissions, [
      "create {$bundle} content",
      "edit any {$bundle} content",
      "delete any {$bundle} content",
    ]);
  }

  _gprep_homepage_manager_ensure_role_permissions('administrator', [
    'access gprep editorial dashboard',
    'administer gprep site settings',
  ]);
  _gprep_homepage_manager_create_or_update_role('gprep_content_editor', 'GPREP Content Editor', $editor_permissions);
  _gprep_homepage_manager_create_or_update_role('gprep_site_manager', 'GPREP Site Manager', $site_manager_permissions);
}

/**
 * Adds an integer field.
 */
function _gprep_homepage_manager_add_integer_field(string $field_name, string $label, array $bundles): void {
  if (!FieldStorageConfig::loadByName('node', $field_name)) {
    FieldStorageConfig::create([
      'field_name' => $field_name,
      'entity_type' => 'node',
      'type' => 'integer',
    ])->save();
  }

  foreach ($bundles as $bundle) {
    if (!FieldConfig::loadByName('node', $bundle, $field_name)) {
      FieldConfig::create([
        'field_name' => $field_name,
        'entity_type' => 'node',
        'bundle' => $bundle,
        'label' => $label,
      ])->save();
    }
  }
}

/**
 * Adds a string field.
 */
function _gprep_homepage_manager_add_string_field(string $field_name, string $label, array $bundles, int $max_length): void {
  if (!FieldStorageConfig::loadByName('node', $field_name)) {
    FieldStorageConfig::create([
      'field_name' => $field_name,
      'entity_type' => 'node',
      'type' => 'string',
      'settings' => ['max_length' => $max_length],
    ])->save();
  }

  foreach ($bundles as $bundle) {
    if (!FieldConfig::loadByName('node', $bundle, $field_name)) {
      FieldConfig::create([
        'field_name' => $field_name,
        'entity_type' => 'node',
        'bundle' => $bundle,
        'label' => $label,
      ])->save();
    }
  }
}

/**
 * Adds a long text field.
 */
function _gprep_homepage_manager_add_text_long_field(string $field_name, string $label, array $bundles): void {
  if (!FieldStorageConfig::loadByName('node', $field_name)) {
    FieldStorageConfig::create([
      'field_name' => $field_name,
      'entity_type' => 'node',
      'type' => 'text_long',
    ])->save();
  }

  foreach ($bundles as $bundle) {
    if (!FieldConfig::loadByName('node', $bundle, $field_name)) {
      FieldConfig::create([
        'field_name' => $field_name,
        'entity_type' => 'node',
        'bundle' => $bundle,
        'label' => $label,
      ])->save();
    }
  }
}

/**
 * Adds a link field.
 */
function _gprep_homepage_manager_add_link_field(string $field_name, string $label, array $bundles): void {
  if (!FieldStorageConfig::loadByName('node', $field_name)) {
    FieldStorageConfig::create([
      'field_name' => $field_name,
      'entity_type' => 'node',
      'type' => 'link',
    ])->save();
  }

  foreach ($bundles as $bundle) {
    if (!FieldConfig::loadByName('node', $bundle, $field_name)) {
      FieldConfig::create([
        'field_name' => $field_name,
        'entity_type' => 'node',
        'bundle' => $bundle,
        'label' => $label,
      ])->save();
    }
  }
}

/**
 * Adds a node reference field.
 */
function _gprep_homepage_manager_add_node_reference_field(string $field_name, string $label, array $bundles, string $target_bundle): void {
  if (!FieldStorageConfig::loadByName('node', $field_name)) {
    FieldStorageConfig::create([
      'field_name' => $field_name,
      'entity_type' => 'node',
      'type' => 'entity_reference',
      'settings' => [
        'target_type' => 'node',
      ],
      'cardinality' => -1,
    ])->save();
  }

  foreach ($bundles as $bundle) {
    if (!FieldConfig::loadByName('node', $bundle, $field_name)) {
      FieldConfig::create([
        'field_name' => $field_name,
        'entity_type' => 'node',
        'bundle' => $bundle,
        'label' => $label,
        'settings' => [
          'handler' => 'default:node',
          'handler_settings' => [
            'target_bundles' => [
              $target_bundle => $target_bundle,
            ],
          ],
        ],
      ])->save();
    }
  }
}

/**
 * Adds an image field.
 */
function _gprep_homepage_manager_add_image_field(string $field_name, string $label, array $bundles): void {
  if (!FieldStorageConfig::loadByName('node', $field_name)) {
    FieldStorageConfig::create([
      'field_name' => $field_name,
      'entity_type' => 'node',
      'type' => 'image',
      'settings' => [
        'uri_scheme' => 'public',
        'default_image' => ['uuid' => NULL, 'alt' => '', 'title' => '', 'width' => NULL, 'height' => NULL],
      ],
    ])->save();
  }

  foreach ($bundles as $bundle) {
    if (!FieldConfig::loadByName('node', $bundle, $field_name)) {
      FieldConfig::create([
        'field_name' => $field_name,
        'entity_type' => 'node',
        'bundle' => $bundle,
        'label' => $label,
      ])->save();
    }
  }
}

/**
 * Creates a simple node teaser view with one block display.
 */
function _gprep_homepage_manager_ensure_node_view(string $view_id, string $label, string $bundle, int $items_per_page, array $sorts): void {
  if (View::load($view_id)) {
    return;
  }

  $sort_config = [];
  foreach ($sorts as $field_name => $order) {
    if ($field_name === 'created') {
      $sort_config['created'] = [
        'id' => 'created',
        'table' => 'node_field_data',
        'field' => 'created',
        'plugin_id' => 'date',
        'entity_type' => 'node',
        'entity_field' => 'created',
        'order' => $order,
      ];
      continue;
    }

    $sort_config[$field_name] = [
      'id' => $field_name,
      'table' => 'node__field_display_order',
      'field' => 'field_display_order_value',
      'plugin_id' => 'standard',
      'order' => $order,
    ];
  }

  $view = View::create([
    'id' => $view_id,
    'label' => $label,
    'module' => 'views',
    'description' => $label,
    'tag' => 'default',
    'base_table' => 'node_field_data',
    'base_field' => 'nid',
    'dependencies' => [
      'module' => ['node', 'user'],
    ],
    'display' => [
      'default' => [
        'id' => 'default',
        'display_title' => 'Default',
        'display_plugin' => 'default',
        'position' => 0,
        'display_options' => [
          'title' => '',
          'access' => [
            'type' => 'perm',
            'options' => ['perm' => 'access content'],
          ],
          'cache' => [
            'type' => 'tag',
            'options' => [],
          ],
          'query' => [
            'type' => 'views_query',
            'options' => [],
          ],
          'pager' => [
            'type' => 'some',
            'options' => [
              'items_per_page' => $items_per_page,
              'offset' => 0,
            ],
          ],
          'style' => [
            'type' => 'default',
            'options' => [
              'uses_fields' => FALSE,
            ],
          ],
          'row' => [
            'type' => 'entity:node',
            'options' => [
              'view_mode' => 'teaser',
            ],
          ],
          'filters' => [
            'status' => [
              'id' => 'status',
              'table' => 'node_field_data',
              'field' => 'status',
              'plugin_id' => 'boolean',
              'entity_type' => 'node',
              'entity_field' => 'status',
              'value' => '1',
            ],
            'type' => [
              'id' => 'type',
              'table' => 'node_field_data',
              'field' => 'type',
              'plugin_id' => 'bundle',
              'entity_type' => 'node',
              'entity_field' => 'type',
              'value' => [
                $bundle => $bundle,
              ],
            ],
          ],
          'sorts' => $sort_config,
        ],
      ],
      'block_1' => [
        'id' => 'block_1',
        'display_title' => 'Block',
        'display_plugin' => 'block',
        'position' => 1,
        'display_options' => [
          'block_description' => $label,
          'block_category' => 'GPREP',
        ],
      ],
    ],
  ]);

  $view->save();
}

/**
 * Ensures the News Item content form exposes all editorial fields.
 */
function _gprep_homepage_manager_ensure_news_item_form_display(): void {
  $display = EntityFormDisplay::load('node.news_item.default');
  if (!$display) {
    $display = EntityFormDisplay::create([
      'targetEntityType' => 'node',
      'bundle' => 'news_item',
      'mode' => 'default',
      'status' => TRUE,
    ]);
