  $display
    ->setComponent('title', [
      'type' => 'string_textfield',
      'weight' => 0,
      'region' => 'content',
      'settings' => ['size' => 60, 'placeholder' => 'News title'],
    ])
    ->setComponent('field_resource_summary', [
      'type' => 'text_textarea',
      'weight' => 1,
      'region' => 'content',
      'settings' => ['rows' => 6, 'placeholder' => 'Short summary for cards and listings'],
    ])
    ->setComponent('field_news_body', [
      'type' => 'text_textarea',
      'weight' => 2,
      'region' => 'content',
      'settings' => ['rows' => 14, 'placeholder' => 'Full news content'],
    ])
    ->setComponent('field_card_image', [
      'type' => 'image_image',
      'weight' => 3,
      'region' => 'content',
      'settings' => ['progress_indicator' => 'throbber'],
    ])
    ->setComponent('field_display_date', [
      'type' => 'string_textfield',
      'weight' => 4,
      'region' => 'content',
      'settings' => ['size' => 30, 'placeholder' => '14 Jun 2025'],
    ])
    ->setComponent('field_display_time', [
      'type' => 'string_textfield',
      'weight' => 5,
      'region' => 'content',
      'settings' => ['size' => 20, 'placeholder' => '11:15 AM'],
    ])
    ->setComponent('field_incident', [
      'type' => 'options_select',
      'weight' => 6,
      'region' => 'content',
      'settings' => [],
    ])
    ->setComponent('field_source_url', [
      'type' => 'link_default',
      'weight' => 7,
      'region' => 'content',
      'settings' => ['placeholder_url' => 'https://www.gprep.ca/...'],
    ])
    ->setComponent('field_button_text', [
      'type' => 'string_textfield',
      'weight' => 8,
      'region' => 'content',
      'settings' => ['size' => 30, 'placeholder' => 'Read More'],
    ])
    ->setComponent('field_button_link', [
      'type' => 'link_default',
      'weight' => 9,
      'region' => 'content',
      'settings' => ['placeholder_url' => '/news/example'],
    ])
    ->setComponent('field_display_order', [
      'type' => 'number',
      'weight' => 10,
      'region' => 'content',
      'settings' => ['placeholder' => '0'],
    ])
    ->save();
}

/**
 * Ensures a content type has a working editor form display.
 */
function _gprep_homepage_manager_ensure_form_display(string $bundle, array $components): void {
  $display = EntityFormDisplay::load("node.$bundle.default");
  if (!$display) {
    $display = EntityFormDisplay::create([
      'targetEntityType' => 'node',
      'bundle' => $bundle,
      'mode' => 'default',
      'status' => TRUE,
    ]);
  }

  foreach ($components as $field_name => $component) {
    $display->setComponent($field_name, [
      'type' => $component['type'],
      'weight' => $component['weight'],
      'region' => 'content',
      'settings' => $component['settings'] ?? [],
      'third_party_settings' => [],
    ]);
  }

  $display->save();
}

/**
 * Updates a field label/description when the field exists.
 */
function _gprep_homepage_manager_update_field_metadata(string $entity_type, string $bundle, string $field_name, string $label, string $description = ''): void {
  if ($field = FieldConfig::loadByName($entity_type, $bundle, $field_name)) {
    $field->setLabel($label);
    $field->setDescription($description);
    $field->save();
  }
}

/**
 * Ensures a basic custom block exists with the provided markup.
 */
function _gprep_homepage_manager_ensure_basic_block(string $info, string $body_value): BlockContent {
  $storage = \Drupal::entityTypeManager()->getStorage('block_content');
  $matches = $storage->loadByProperties([
    'type' => 'basic',
    'info' => $info,
  ]);
  /** @var \Drupal\block_content\Entity\BlockContent|null $block_content */
  $block_content = $matches ? reset($matches) : NULL;
  if (!$block_content) {
    $block_content = BlockContent::create([
      'type' => 'basic',
      'info' => $info,
      'body' => [
        'value' => $body_value,
        'format' => 'full_html',
      ],
    ]);
  }
  else {
    $block_content->set('body', [
      'value' => $body_value,
      'format' => 'full_html',
    ]);
  }
  $block_content->save();

  return $block_content;
}

/**
 * Places a custom block into the given theme region.
 */
function _gprep_homepage_manager_place_block(string $block_id, string $uuid, string $region, int $weight = 0): void {
  $plugin_id = 'block_content:' . $uuid;
  $block = Block::load($block_id);
  if (!$block) {
    $block = Block::create([
      'id' => $block_id,
      'theme' => 'gprep_theme',
      'region' => $region,
      'plugin' => $plugin_id,
      'weight' => $weight,
      'visibility' => [
        'request_path' => [
          'id' => 'request_path',
          'pages' => '<front>',
          'negate' => FALSE,
          'context_mapping' => [],
        ],
      ],
      'settings' => [
        'id' => $plugin_id,
        'label' => '',
        'label_display' => FALSE,
        'provider' => 'block_content',
        'status' => TRUE,
        'view_mode' => 'full',
      ],
    ]);
  }
  else {
    $block->setRegion($region);
    $block->setPlugin($plugin_id);
    $block->set('settings', [
      'id' => $plugin_id,
      'label' => '',
      'label_display' => FALSE,
      'provider' => 'block_content',
      'status' => TRUE,
      'view_mode' => 'full',
    ]);
    $block->set('visibility', [
      'request_path' => [
        'id' => 'request_path',
        'pages' => '<front>',
        'negate' => FALSE,
        'context_mapping' => [],
      ],
    ]);
    $block->setWeight($weight);
  }
  $block->save();
}

/**
 * Creates or updates a role to match the target permission set.
 */
function _gprep_homepage_manager_create_or_update_role(string $id, string $label, array $permissions): void {
  $role = Role::load($id);
  if (!$role) {
    $role = Role::create([
      'id' => $id,
      'label' => $label,
    ]);
  }
  else {
    $role->set('label', $label);
  }

  $available_permissions = array_keys(\Drupal::service('user.permissions')->getPermissions());
  $target_permissions = array_values(array_intersect(array_unique($permissions), $available_permissions));

  foreach ($role->getPermissions() as $permission) {
    $role->revokePermission($permission);
  }
  foreach ($target_permissions as $permission) {
    $role->grantPermission($permission);
  }
  $role->save();
}

/**
 * Ensures an existing role receives additional permissions.
 */
function _gprep_homepage_manager_ensure_role_permissions(string $id, array $permissions): void {
  $role = Role::load($id);
  if (!$role) {
    return;
  }

  $available_permissions = array_keys(\Drupal::service('user.permissions')->getPermissions());
  foreach (array_intersect(array_unique($permissions), $available_permissions) as $permission) {
    $role->grantPermission($permission);
  }
  $role->save();
}
